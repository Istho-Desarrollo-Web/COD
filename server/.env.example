NODE_ENV=development
PORT=5000
# APP_URL: solo informativo (se imprime en el log de arranque). En producción,
# ponga aquí el dominio público real (ej. https://api.cod.istho.com.co) — si se
# omite en producción, el arranque solo muestra el puerto, sin inventar un host.
# APP_URL=https://api.cod.istho.com.co
JWT_SECRET=cambiar_por_un_secreto_aleatorio_de_al_menos_32_caracteres
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=cod_dev
DB_USER=root
DB_PASSWORD=
DB_POOL_MAX=5
CORS_ORIGIN=http://localhost:5173
# CRON_RECALCULO_ESTADOS: expresión cron para el job diario que recalcula el
# estado (vigente/por_vencer/vencido) de todos los documentos activos y la
# salud documental de sus áreas. Por defecto corre todos los días a las 3am.
# CRON_RECALCULO_ESTADOS=0 3 * * *
